{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "./gradlew :backend:shadowJar --no-daemon"
  },
  "deploy": {
    "startCommand": "java -jar backend/build/libs/lifelog-backend-all.jar",
    "restartPolicyType": "ON_FAILURE",
    "healthcheckPath": "/api/projects"
  }
}
